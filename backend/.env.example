# Copy to .env and fill in. The key stays server-side — never ship it to the frontend.
# Get a Gemini API key at https://aistudio.google.com/apikey (starts with "AIza...").
GEMINI_API_KEY=AIza...

# gemini-2.5-flash = fast + cheap (good for the demo). gemini-2.5-pro for max quality.
GEMINI_MODEL=gemini-2.5-flash

# Set to 1 to skip the AI entirely and mint cards from a deterministic mock.
# Flip this on if the venue wifi blocks the Gemini endpoint — the demo still works.
MOCK_MODE=0

PORT=8787
