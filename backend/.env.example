# Copy to .env and paste a key to run live AI on your machine.
# The key stays server-side — never ship it to the frontend.
# Get one at https://console.anthropic.com/settings/keys (starts with sk-ant-).
ANTHROPIC_API_KEY=sk-ant-...

# claude-haiku-4-5-20251001 = fast + cheap (good for the demo).
# claude-sonnet-4-6 for richer card text.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Set to 1 to skip the AI entirely and mint cards from a deterministic mock.
# The app still works fully in mock mode — good if you have no key yet.
MOCK_MODE=0

PORT=8787

# ---------------------------------------------------------------------------
# Only used by `npm run seed:images` (one-time upload of seed card art to
# Supabase Storage). NOT used by the running server. The service_role key is
# secret — never expose it to the browser. Project Settings -> API.
# ---------------------------------------------------------------------------
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-secret...
